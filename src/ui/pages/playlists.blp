using Gtk 4.0;
using Adw 1;

template $NocturnePlaylistsPage: Adw.NavigationPage {
  title: _("Playlists");
  tag: "playlists";
  child: Adw.ToolbarView {
    [top]
    Adw.HeaderBar {
      [start]
      Gtk.Button {
        styles [
          "flat"
        ]
        icon-name: "list-add-symbolic";
        tooltip-text: _("Create Playlist");
        action-name: "app.create_playlist";
      }

      title-widget: Gtk.SearchEntry {
        hexpand: true;
        placeholder-text: _("Playlists");
        search-changed => $on_search();
      };
    }

    content: Gtk.ScrolledWindow {
      propagate-natural-width: true;
      propagate-natural-height: true;

      child: Adw.Clamp {
        maximum-size: 2000;
        tightening-threshold: 800;
        Gtk.Box {
          orientation: vertical;
          spacing: 5;

          Gtk.ListBox list_el {
            styles [
              "boxed-list"
            ]
            margin-top: 10;
            margin-bottom: 10;
            margin-start: 10;
            margin-end: 10;
            selection-mode: none;
            valign: start;
          }
        }
      };
    };
  };
}